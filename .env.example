# Agentscape environment — copy to .env.local and fill in. Never commit .env.local.
# Get these from your Supabase project: Settings → API. Use the NEW API keys
# (sb_publishable_… / sb_secret_…); the legacy anon/service_role keys also work.

# Canonical site origin for metadata (canonical + OG/Twitter URLs). Optional —
# defaults to the production URL. Set per-environment if you fork/redeploy.
NEXT_PUBLIC_SITE_URL=https://agentscape-kappa.vercel.app

# Project URL (browser-safe).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable key — browser-safe ONLY because RLS protects every row. Used for all
# reads and the whole auth flow; requests run under the signed-in user's session.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Secret key — SERVER ONLY, bypasses RLS. Never ship to the client. Used only by
# the seed script and the trusted domain-verify write (lib/supabase/admin.ts).
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx

# Upstash Redis (Phase 5b) — rate limiting on writes + auth. Create a database at
# upstash.com → REST API. OPTIONAL: if BOTH are absent, rate limiting fails OPEN
# (disabled, with a logged warning) — local dev and the public/machine demo are
# unaffected. Set BOTH in production (Vercel env) to make limiting active.
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REST_TOKEN
